{
  "name": "greenlight",
  "version": "0.0.1",
  "description": "Gates go in red. Code comes out. Gates turn green. Everything in between is liquid.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "greenlight": "./bin/greenlight.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "dev": "wrangler dev --port 8787 --local",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/ test/",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "npm run typecheck && npm run lint",
    "build": "tsc",
    "proof": "node scripts/proof-bundle.mjs"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "durable-objects",
    "gates",
    "testing",
    "ai",
    "agent",
    "self-building"
  ],
  "author": "acoyfellow",
  "license": "MIT",
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.3",
    "@cloudflare/workers-types": "^4.20250620.0",
    "oxlint": "^1.56.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "hono": "^4.12.8",
    "jose": "^6.2.2"
  }
}
